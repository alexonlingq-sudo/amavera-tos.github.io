import {
  View, Text, StyleSheet, TouchableOpacity, SafeAreaView,
  TextInput, Alert, ActivityIndicator, KeyboardAvoidingView, Platform,
  Linking
} from 'react-native';
import { useState, useEffect, useRef } from 'react';
import { supabase } from '../supabase';
import { API_BASE_URL } from './config';
import useLockPortrait from './useLockPortrait';

const API_BASE = API_BASE_URL;

export default function AccountCreationScreen({ route, navigation }) {
  const { address, inspectionId, report, intent, email: prefillEmail } = route.params;
  // intent: 'save' | 'purchase'

  useLockPortrait();

  const [email, setEmail] = useState(prefillEmail || '');
  const [password, setPassword] = useState('');
  const [confirmPassword, setConfirmPassword] = useState('');
  const [processing, setProcessing] = useState(false);

  const passwordRef = useRef(null);
  const confirmPasswordRef = useRef(null);

  const isSave = intent === 'save';

  useEffect(() => {
    supabase.auth.getSession().then(async ({ data }) => {
      const userId = data?.session?.user?.id;
      if (!userId) return;
      // Already signed in — link inspection and skip this screen
      if (inspectionId) {
        try {
          await fetch(`${API_BASE}/inspections/${inspectionId}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ user_id: userId }),
          });
        } catch {}
      }
      if (isSave) {
        navigation.replace('ReportSaved', { address, inspectionId, report, email: email.trim() });
      } else {
        navigation.replace('PaymentGate', { address, inspectionId, report, email: email.trim() });
      }
    });
  }, []);

  const heading = isSave
    ? 'Create an account to save your report for free'
    : 'Create an account to purchase your report';

  const sub = isSave
    ? 'No payment required — your inspection will be saved and accessible anytime from Past Inspections.'
    : 'Your account keeps your report safe and lets you access it across devices after purchase.';

  const btnLabel = isSave ? 'Save My Report' : 'Continue to Payment';

  async function handleSubmit() {
    if (!email.trim() || !password.trim() || !confirmPassword.trim()) {
      Alert.alert('Required', 'Please fill in all fields to continue.');
      return;
    }
    if (password.trim().length < 6) {
      Alert.alert('Password too short', 'Password must be at least 6 characters.');
      return;
    }
    if (password.trim() !== confirmPassword.trim()) {
      Alert.alert("Passwords don't match", 'Please make sure both passwords are the same.');
      return;
    }

    setProcessing(true);

    try {
      const { data, error } = await supabase.auth.signUp({
        email: email.trim(),
        password: password.trim(),
      });

      if (error) {
        Alert.alert('Account error', error.message);
        return;
      }

      const userId = data?.user?.id || null;

      // Link userId to inspection
      if (userId && inspectionId) {
        try {
          await fetch(`${API_BASE}/inspections/${inspectionId}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ user_id: userId }),
          });
        } catch (err) {
          console.error('Failed to link userId to inspection:', err);
        }
      }

      if (isSave) {
        navigation.navigate('ReportSaved', { address, inspectionId, report, email: email.trim() });
      } else {
        navigation.navigate('PaymentGate', { address, inspectionId, report, email: email.trim() });
      }

    } catch (err) {
      Alert.alert('Error', 'Something went wrong. Please try again.');
      console.error('AccountCreation error:', err);
    } finally {
      setProcessing(false);
    }
  }

  return (
    <KeyboardAvoidingView
      style={{ flex: 1 }}
      behavior={Platform.OS === 'ios' ? 'padding' : 'height'}
      keyboardVerticalOffset={Platform.OS === 'ios' ? 0 : 24}
    >
      <SafeAreaView style={styles.container}>
        <View style={styles.content}>

          <Text style={styles.heading}>{heading}</Text>
          <Text style={styles.sub}>{sub}</Text>

          <TextInput
            style={styles.input}
            placeholder="Email address"
            value={email}
            onChangeText={setEmail}
            autoCapitalize="none"
            keyboardType="email-address"
            returnKeyType="next"
            onSubmitEditing={() => passwordRef.current?.focus()}
            autoFocus
            editable={!processing}
          />
          <TextInput
            ref={passwordRef}
            style={styles.input}
            placeholder="Create a password (min. 6 characters)"
            value={password}
            onChangeText={setPassword}
            secureTextEntry
            returnKeyType="next"
            onSubmitEditing={() => confirmPasswordRef.current?.focus()}
            editable={!processing}
          />
          <TextInput
            ref={confirmPasswordRef}
            style={styles.input}
            placeholder="Confirm password"
            value={confirmPassword}
            onChangeText={setConfirmPassword}
            secureTextEntry
            returnKeyType="done"
            onSubmitEditing={handleSubmit}
            editable={!processing}
          />

        </View>

        <View style={styles.footer}>
          <TouchableOpacity
            style={[styles.btn, processing && styles.btnDisabled]}
            onPress={handleSubmit}
            disabled={processing}
          >
            {processing
              ? <ActivityIndicator color="#fff" />
              : <Text style={styles.btnText}>{btnLabel}</Text>
            }
          </TouchableOpacity>

          <Text style={styles.legalText}>
            By creating an account, you agree to our{' '}
            <Text
              style={styles.legalLink}
              onPress={() => Linking.openURL('https://alexonlingq-sudo.github.io/amavera-terms.github.io/')}
            >
              Terms of Service
            </Text>
            {' '}and{' '}
            <Text
              style={styles.legalLink}
              onPress={() => Linking.openURL('https://alexonlingq-sudo.github.io/amavera-privacy.github.io/')}
            >
              Privacy Policy
            </Text>
            .
          </Text>

          <TouchableOpacity
            style={styles.signInLink}
            onPress={() => navigation.navigate('SignIn', { address, inspectionId, report, intent, email: email.trim() })}
            disabled={processing}
          >
            <Text style={styles.signInLinkText}>Already have an account? Sign in</Text>
          </TouchableOpacity>
        </View>

      </SafeAreaView>
    </KeyboardAvoidingView>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1, backgroundColor: '#fff',
    paddingHorizontal: 24, paddingBottom: 40,
    justifyContent: 'space-between',
  },
  content: { flex: 1, justifyContent: 'center' },
  heading: {
    fontSize: 26, fontWeight: '700', color: '#1e293b',
    letterSpacing: -0.5, marginBottom: 10,
  },
  sub: {
    fontSize: 15, color: '#64748b', lineHeight: 22, marginBottom: 32,
  },
  input: {
    borderWidth: 2, borderColor: '#e2e8f0', borderRadius: 12,
    paddingHorizontal: 16, paddingVertical: 14,
    fontSize: 16, color: '#1e293b', marginBottom: 12,
  },
  footer: { paddingTop: 12, gap: 16 },
  btn: {
    backgroundColor: '#2563eb', paddingVertical: 18,
    borderRadius: 14, alignItems: 'center',
  },
  btnDisabled: { backgroundColor: '#93c5fd' },
  btnText: { color: '#fff', fontSize: 17, fontWeight: '600' },
  signInLink: { alignItems: 'center' },
  signInLinkText: { color: '#2563eb', fontSize: 15, fontWeight: '500' },
  legalText: {
    fontSize: 13, color: '#94a3b8', textAlign: 'center',
    lineHeight: 18,
  },
  legalLink: {
    color: '#2563eb', textDecorationLine: 'underline',
  },
});
